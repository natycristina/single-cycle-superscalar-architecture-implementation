initial 

begin 
$timeformat(-12,3," ps",6);
#350000;
if (nummismatches > 0)
	$display ("%d mismatched vectors : Simulation failed !",nummismatches);
else
	$display ("Simulation passed !");
$finish;
end 
endmodule

module top_dual_vlg_vec_tst();
// constants                                           
// general purpose registers
reg clk;
reg reset;
// wires                                               
wire [31:0] DataAdr0;
wire [31:0] DataAdr1;
wire [31:0] Instr0_DBG;
wire [31:0] Instr1_DBG;
wire MemWrite0;
wire MemWrite1;
wire [31:0] PC_DBG;
wire [31:0] WriteData0;
wire [31:0] WriteData1;

wire sampler;                             

// assign statements (if any)                          
top_dual i1 (
// port map - connection between master ports and signals/registers   
	.DataAdr0(DataAdr0),
	.DataAdr1(DataAdr1),
	.Instr0_DBG(Instr0_DBG),
	.Instr1_DBG(Instr1_DBG),
	.MemWrite0(MemWrite0),
	.MemWrite1(MemWrite1),
	.PC_DBG(PC_DBG),
	.WriteData0(WriteData0),
	.WriteData1(WriteData1),
	.clk(clk),
	.reset(reset)
);

// reset
initial
begin
	reset = 1'b0;
end 

// clk
always
begin
	clk = 1'b0;
	clk = #5000 1'b1;
	#5000;
end 

top_dual_vlg_sample_tst tb_sample (
	.clk(clk),
	.reset(reset),
	.sampler_tx(sampler)
);

top_dual_vlg_check_tst tb_out(
	.DataAdr0(DataAdr0),
	.DataAdr1(DataAdr1),
	.Instr0_DBG(Instr0_DBG),
	.Instr1_DBG(Instr1_DBG),
	.MemWrite0(MemWrite0),
	.MemWrite1(MemWrite1),
	.PC_DBG(PC_DBG),
	.WriteData0(WriteData0),
	.WriteData1(WriteData1),
	.sampler_rx(sampler)
);
endmodule

