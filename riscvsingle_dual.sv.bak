module riscvsingle_dual (
    input  logic        clk, reset,

    output logic [31:0] PC,
    input  logic [31:0] Instr0, Instr1,
    output logic        MemWrite0, MemWrite1,
    output logic [31:0] ALUResult0, WriteData0, ALUResult1, WriteData1,
    input  logic [31:0] ReadData0, ReadData1
);

  // sinais de controle instr0
  logic [1:0] ResultSrc0, ImmSrc0;
  logic       ALUSrc0, RegWrite0, Jump0;
  logic [3:0] ALUControl0;
  logic       Zero0, LT0;
  logic       PCSrc0;

  // sinais de controle instr1
  logic [1:0] ResultSrc1, ImmSrc1;
  logic       ALUSrc1, RegWrite1, Jump1;
  logic [3:0] ALUControl1;
  logic       Zero1, LT1;

  // === Controladores ===
  // controller module ports: (op, funct3, funct7b5, funct7[6:0], Zero, LT, ResultSrc, MemWrite, PCSrc, ALUSrc, RegWrite, Jump, ImmSrc, ALUControl)
  controller c0(
      .op        (Instr0[6:0]),
      .funct3    (Instr0[14:12]),
      .funct7b5  (Instr0[30]),
      .funct7    (Instr0[31:25]),
      .Zero      (Zero0),
      .LT        (LT0),
      .ResultSrc (ResultSrc0),
      .MemWrite  (MemWrite0),
      .PCSrc     (PCSrc0),
      .ALUSrc    (ALUSrc0),
      .RegWrite  (RegWrite0),
      .Jump      (Jump0),
      .ImmSrc    (ImmSrc0),
      .ALUControl(ALUControl0)
  );

  controller c1(
      .op        (Instr1[6:0]),
      .funct3    (Instr1[14:12]),
      .funct7b5  (Instr1[30]),
      .funct7    (Instr1[31:25]),
      .Zero      (Zero1),
      .LT        (LT1),
      .ResultSrc (ResultSrc1),
      .MemWrite  (MemWrite1),
      .PCSrc     (),              
      .ALUSrc    (ALUSrc1),
      .RegWrite  (RegWrite1),
      .Jump      (Jump1),
      .ImmSrc    (ImmSrc1),
      .ALUControl(ALUControl1)
  );

  // === Datapath Dual ===
  datapath_dual dp(
      .clk(clk), .reset(reset),

      // instr0
      .ResultSrc0(ResultSrc0),
      .ImmSrc0(ImmSrc0),
      .ALUSrc0(ALUSrc0),
      .RegWrite0(RegWrite0),
      .PCSrc0(PCSrc0),
      .ALUControl0(ALUControl0),
	  .MemWrite0(MemWrite0D),

      // instr1
      .ResultSrc1(ResultSrc1),
      .ImmSrc1(ImmSrc1),
      .ALUSrc1(ALUSrc1),
      .RegWrite1(RegWrite1),
      .ALUControl1(ALUControl1),
	  .MemWrite1(MemWrite1D),

      // outputs
      .PC(PC),
      .Zero0(Zero0), .LT0(LT0),
      .Zero1(Zero1), .LT1(LT1),
      .Instr0F(Instr0), .Instr1F(Instr1),

      // data memory
      .ReadData0(ReadData0), .ReadData1(ReadData1),
      .ALUResult0(ALUResult0), .ALUResult1(ALUResult1),
      .WriteData0(WriteData0), .WriteData1(WriteData1),
	  .MemWrite0_out(MemWrite0M),
	  .MemWrite1_out(MemWrite1M),
	  
  );

endmodule
